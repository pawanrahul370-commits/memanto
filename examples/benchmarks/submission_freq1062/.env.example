# =============================================================================
# Memanto Benchmark — Environment Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
# Then fill in your API keys below.
#
# KEY ROTATION: For services with rate-limited free tiers, add numbered keys:
#   SERVICE_KEY_1=key1
#   SERVICE_KEY_2=key2
#   SERVICE_KEY_3=key3
#   ...
# The benchmark automatically rotates through numbered keys (1..N) when it
# hits rate limits or namespace caps. Works with Groq, Moorcheh, Zep,
# and Supermemory.
#
# If a base key (SERVICE_KEY) is also set, it's used first, then numbered
# keys are tried. For 5 services × N keys each, you get 5×N times the
# free-tier throughput. We used 10 Moorcheh keys for the LoCoMo benchmark.

# --- Local model path (for embeddings + LLM judge) ---
# Download from HuggingFace:
#   hf download Qwen/Qwen2.5-1.5B-Instruct-GGUF qwen2.5-1.5b-instruct-q4_k_m.gguf --local-dir ~/models
BENCH_MODEL_PATH=~/models/qwen2.5-1.5b-instruct-q4_k_m.gguf

# ---------------------------------------------------------------------------
# Memanto / Moorcheh — cloud memory (5 namespaces/key free tier)
# ---------------------------------------------------------------------------
MOORCHEH_API_KEY=your_moorcheh_key_here
# MOORCHEH_API_KEY_1=
# MOORCHEH_API_KEY_2=
# ... add numbered keys up to _N for rotation

# ---------------------------------------------------------------------------
# Supermemory — cloud memory (async indexing, use small subsets)
# ---------------------------------------------------------------------------
SUPERMEMORY_API_KEY=your_supermemory_key_here
# SUPERMEMORY_API_KEY_1=

# ---------------------------------------------------------------------------
# Zep — cloud graph memory (300 calls/key free tier)
# ---------------------------------------------------------------------------
ZEP_API_KEY=your_zep_key_here
# ZEP_API_KEY_1=

# ---------------------------------------------------------------------------
# Groq — LLM provider (optional, for mem0 infer=True extraction)
# ---------------------------------------------------------------------------
# GROQ_API_KEY=your_groq_key_here
# GROQ_API_KEY_1=
